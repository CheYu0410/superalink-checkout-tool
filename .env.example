# Stripe publishable key used by the official Superalink checkout frontend.
# Do not commit real secret keys. Publishable keys are not secret, but keep deployment-specific values in env.
STRIPE_PK=pk_live_xxx

# PayPal client id used for rendering PayPal buttons.
PAYPAL_CLIENT_ID=xxx

# Optional: Apple Pay merchant domain association file path.
APPLE_PAY_DOMAIN_ASSOCIATION_FILE=./apple-developer-merchantid-domain-association
